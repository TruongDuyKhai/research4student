# ── Server ──────────────────────────────────────────────────────────
PORT=4000
CLIENT_URL=http://localhost:5173
JWT_SECRET=
JWT_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=
ADMIN_EMAIL=admin@research4student.io.vn
ADMIN_PASSWORD=change-me-please
DISCORD_BOT_TOKEN=
DISCORD_STORAGE_CHANNEL_ID=
MAX_UPLOAD_SIZE_MB=10
CDN_REFRESH_CRON=*/10 * * * *
# Re-sign a CDN URL this many minutes before it actually expires
CDN_REFRESH_MARGIN_MINUTES=60
# Absolute origin of the API, only needed when the client is served from a
# different domain than the server. Empty = emit relative /api/files/:id/raw URLs.
PUBLIC_FILE_BASE_URL=
TURNSTILE_SECRET_KEY=

# ── Client (Vite) ────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:4000/api
VITE_GOOGLE_CLIENT_ID=
VITE_ADMIN_ROUTE=/portal-mgmt-7f3a
VITE_TURNSTILE_SITE_KEY=
